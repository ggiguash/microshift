# Address the problem with image upgrades overwriting the container images in
# additional store. The work around is to copy the images from the pre-loaded
# to the main container storage directory.
# See https://issues.redhat.com/browse/RHEL-75827
[Unit]
ConditionPathExists=/usr/bin/podman
ConditionPathExists=/usr/bin/skopeo

[Service]
ExecStartPre=/bin/bash -eux -o pipefail -c '\
SRC_PATH="/usr/lib/containers/storage" ; \
DST_PATH="/var/lib/containers/storage" ; \
for img in $(/usr/bin/podman images --root=${SRC_PATH} --format '{{"{{"}}.Repository{{"}}"}}:{{"{{"}}.Tag{{"}}"}}') ; do \
    /usr/bin/skopeo copy containers-storage:${SRC_PATH}:${img} containers-storage:${DST_PATH}:${img} ; \
done \
'
